{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "foundation-resource-grant-response.schema.json",
  "type": "object",
  "required": ["success", "resourceGrant"],
  "properties": {
    "success": { "type": "boolean" },
    "resourceGrant": {
      "type": "object",
      "required": [
        "grantId",
        "tenantId",
        "sourceAppId",
        "consumerAppId",
        "resourcePackId",
        "selector",
        "actions",
        "startsAt",
        "endsAt",
        "status",
        "createdAt",
        "updatedAt"
      ],
      "properties": {
        "grantId": { "type": "string" },
        "tenantId": { "type": "string" },
        "sourceAppId": {
          "type": "string",
          "enum": ["nesting", "drawing", "ordering", "crm", "aps", "wms", "drive", "foundation_workbench"]
        },
        "consumerAppId": {
          "type": "string",
          "enum": ["nesting", "drawing", "ordering", "crm", "aps", "wms", "drive", "foundation_workbench"]
        },
        "resourcePackId": { "type": "string" },
        "selector": { "type": "object", "additionalProperties": true },
        "actions": {
          "type": "array",
          "items": { "type": "string", "enum": ["read", "write", "share", "delete"] }
        },
        "startsAt": { "type": "string" },
        "endsAt": { "type": "string" },
        "status": { "type": "string", "enum": ["ACTIVE", "REVOKED", "EXPIRED"] },
        "createdBy": { "type": "string" },
        "createdAt": { "type": "string" },
        "updatedAt": { "type": "string" },
        "revokedAt": { "type": "string" }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
