{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "foundation-security-policy-list-response.schema.json",
  "type": "object",
  "required": [
    "items",
    "total"
  ],
  "properties": {
    "items": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "policyId",
          "sourceAppId",
          "allowedConsumers",
          "dataDomain",
          "purpose",
          "retention",
          "revocationMode",
          "status",
          "legalGate",
          "createdAt",
          "updatedAt"
        ],
        "properties": {
          "policyId": {
            "type": "string"
          },
          "sourceAppId": {
            "type": "string",
            "enum": [
              "nesting",
              "drawing",
              "ordering",
              "crm",
              "aps",
              "wms",
              "drive",
              "foundation_workbench"
            ]
          },
          "allowedConsumers": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "enum": [
                "nesting",
                "drawing",
                "ordering",
                "crm",
                "aps",
                "wms",
                "drive",
                "foundation_workbench"
              ]
            }
          },
          "dataDomain": {
            "type": "string",
            "enum": [
              "ORDER",
              "DRAWING",
              "NESTING",
              "INVENTORY",
              "FILE",
              "FOUNDATION_MODEL",
              "CUSTOMER",
              "SCHEDULING"
            ]
          },
          "purpose": {
            "type": "string",
            "enum": [
              "OPS_DISPATCH",
              "PRODUCTION_PLANNING",
              "QUALITY_TRACEABILITY",
              "SUPPLY_CHAIN_COLLAB",
              "FILE_ARCHIVAL",
              "ANALYTICS_REPORTING",
              "CUSTOMER_DELIVERY",
              "ALGORITHM_TRAINING"
            ]
          },
          "retention": {
            "type": "string",
            "enum": [
              "P7D",
              "P30D",
              "P90D",
              "P180D"
            ]
          },
          "revocationMode": {
            "type": "string",
            "enum": [
              "IMMEDIATE_CASCADE",
              "SOFT_GRACE_24H"
            ]
          },
          "status": {
            "type": "string",
            "enum": [
              "ACTIVE",
              "REVOKED"
            ]
          },
          "legalGate": {
            "type": "string",
            "enum": [
              "PASS",
              "WARN",
              "FAIL"
            ]
          },
          "legalReason": {
            "type": "string"
          },
          "metadata": {
            "type": "object",
            "additionalProperties": true
          },
          "createdAt": {
            "type": "string"
          },
          "updatedAt": {
            "type": "string"
          },
          "revokedAt": {
            "type": "string"
          }
        },
        "additionalProperties": false
      }
    },
    "total": {
      "type": "integer",
      "minimum": 0
    }
  },
  "additionalProperties": false
}
