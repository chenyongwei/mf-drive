{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "foundation-app-catalog-item.schema.json",
  "type": "object",
  "required": [
    "appId",
    "name",
    "route",
    "clientId",
    "enabledByUser",
    "requiredBaseScope",
    "launchMode",
    "miniSupported",
    "l1Authorized",
    "resourceGrantCount"
  ],
  "properties": {
    "appId": { "type": "string" },
    "name": { "type": "string" },
    "route": { "type": "string" },
    "clientId": { "type": "string" },
    "enabledByUser": { "type": "boolean" },
    "requiredBaseScope": { "type": "string" },
    "launchMode": { "type": "string", "enum": ["MINI", "NEW_WINDOW"] },
    "miniSupported": { "type": "boolean" },
    "installedAt": { "type": "string" },
    "l1Authorized": { "type": "boolean" },
    "membershipRole": { "type": "string", "enum": ["OWNER", "MEMBER"] },
    "resourceGrantCount": { "type": "integer", "minimum": 0 },
    "authorizationWindow": {
      "type": "object",
      "required": ["startsAt", "endsAt"],
      "properties": {
        "startsAt": { "type": "string" },
        "endsAt": { "type": "string" }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
