{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "drawing-part-recognition-analyze-response.schema.json",
  "type": "object",
  "required": ["fileId", "fileVersion", "inspection", "summary", "recommendedActions"],
  "properties": {
    "fileId": { "type": "string" },
    "fileVersion": { "type": "integer", "minimum": 0 },
    "inspection": { "$ref": "drawing-inspection-result.schema.json" },
    "summary": {
      "type": "object",
      "required": ["totalIssues", "safeAutoCount", "confirmAutoCount", "manualCount"],
      "properties": {
        "totalIssues": { "type": "integer", "minimum": 0 },
        "safeAutoCount": { "type": "integer", "minimum": 0 },
        "confirmAutoCount": { "type": "integer", "minimum": 0 },
        "manualCount": { "type": "integer", "minimum": 0 }
      },
      "additionalProperties": true
    },
    "recommendedActions": {
      "type": "object",
      "required": ["safeAutoFixIssueIds", "confirmIssueIds", "manualIssueIds"],
      "properties": {
        "safeAutoFixIssueIds": {
          "type": "array",
          "items": { "type": "string" }
        },
        "confirmIssueIds": {
          "type": "array",
          "items": { "type": "string" }
        },
        "manualIssueIds": {
          "type": "array",
          "items": { "type": "string" }
        }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
