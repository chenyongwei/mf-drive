{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "drawing-part-recognition-force-set-response.schema.json",
  "type": "object",
  "required": ["fileId", "fileVersion", "created", "inspection"],
  "properties": {
    "fileId": { "type": "string" },
    "fileVersion": { "type": "integer", "minimum": 0 },
    "created": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["partId", "sourceFileId", "sourceEntityIds", "geometry", "entities", "metadata", "createdAt", "storagePath"],
        "properties": {
          "partId": { "type": "string" },
          "sourceFileId": { "type": "string" },
          "sourceEntityIds": { "type": "array", "items": { "type": "string" } },
          "geometry": { "type": "object" },
          "entities": { "type": "array", "items": { "type": "object" } },
          "metadata": { "type": "object" },
          "createdAt": { "type": "string" },
          "storagePath": { "type": "string" }
        },
        "additionalProperties": true
      }
    },
    "inspection": { "$ref": "drawing-inspection-result.schema.json" }
  },
  "additionalProperties": true
}
