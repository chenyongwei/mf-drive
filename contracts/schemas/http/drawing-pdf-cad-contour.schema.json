{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "drawing-pdf-cad-contour.schema.json",
  "type": "object",
  "required": ["id", "closed", "length", "bbox", "entityIds"],
  "properties": {
    "id": { "type": "string" },
    "closed": { "type": "boolean" },
    "length": { "type": "number" },
    "bbox": {
      "type": "object",
      "required": ["minX", "minY", "maxX", "maxY"],
      "properties": {
        "minX": { "type": "number" },
        "minY": { "type": "number" },
        "maxX": { "type": "number" },
        "maxY": { "type": "number" }
      },
      "additionalProperties": false
    },
    "entityIds": {
      "type": "array",
      "items": { "type": "string" }
    }
  },
  "additionalProperties": false
}
