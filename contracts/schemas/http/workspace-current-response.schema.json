{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "workspace-current-response.schema.json",
  "type": "object",
  "required": ["type"],
  "properties": {
    "type": {
      "type": "string",
      "enum": ["personal", "team"]
    },
    "team": {
      "type": "object",
      "required": ["id", "name", "teamCode", "role"],
      "properties": {
        "id": { "type": "integer" },
        "name": { "type": "string" },
        "teamCode": { "type": "string" },
        "role": { "type": "string" }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
