{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["items", "total"],
  "properties": {
    "items": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["artifactId", "tenantId", "containerId", "artifactType", "ownerAppId", "displayName", "mimeType", "currentVersionId", "createdAt", "updatedAt"],
        "properties": {
          "artifactId": { "type": "string" },
          "tenantId": { "type": "string" },
          "containerId": { "type": "string" },
          "artifactType": { "type": "string", "enum": ["DRAWING", "PARTS", "LAYOUT"] },
          "ownerAppId": { "type": "string" },
          "displayName": { "type": "string" },
          "mimeType": { "type": "string" },
          "currentVersionId": { "type": "string" },
          "projectId": { "type": "string" },
          "createdAt": { "type": "string" },
          "updatedAt": { "type": "string" }
        },
        "additionalProperties": true
      }
    },
    "total": {
      "type": "integer",
      "minimum": 0
    }
  },
  "additionalProperties": true
}
