{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "drawing-history-operation.schema.json",
  "type": "object",
  "required": ["operationType", "operationData", "userId", "username", "timestamp", "version"],
  "properties": {
    "id": { "type": ["integer", "string"] },
    "fileId": { "type": "string" },
    "operationType": { "type": "string" },
    "entityId": { "type": "string" },
    "entityIds": {
      "type": "array",
      "items": { "type": "string" }
    },
    "operationData": { "type": "object" },
    "userId": { "type": "string" },
    "username": { "type": "string" },
    "timestamp": { "type": "integer" },
    "version": { "type": "integer", "minimum": 0 }
  },
  "additionalProperties": true
}
