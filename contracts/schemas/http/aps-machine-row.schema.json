{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "aps-machine-row.schema.json",
  "type": "object",
  "required": ["machineId", "name", "category", "status", "capacityHours", "loadHours", "updatedAt"],
  "properties": {
    "machineId": { "type": "string" },
    "name": { "type": "string" },
    "category": { "type": "string", "enum": ["LASER", "PLASMA"] },
    "status": { "type": "string", "enum": ["idle", "busy", "maintenance"] },
    "capacityHours": { "type": "number" },
    "loadHours": { "type": "number" },
    "updatedAt": { "type": "string" }
  },
  "additionalProperties": false
}
