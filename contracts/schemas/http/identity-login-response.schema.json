{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "identity-login-response.schema.json",
  "type": "object",
  "required": ["token", "expiresAt", "user"],
  "properties": {
    "token": { "type": "string" },
    "expiresAt": { "type": "string" },
    "user": {
      "type": "object",
      "required": ["id", "email", "role"],
      "properties": {
        "id": { "type": "string" },
        "email": { "type": "string" },
        "role": { "type": "string" }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
