          "name": { "type": "string" },
          "deviceType": { "type": "string" },
          "controlSystem": { "type": "string" },
          "feedRate": { "type": "number" },
          "rapidRate": { "type": "number" },
          "leadIn": { "type": "object" },
          "leadOut": { "type": "object" },
          "microJoint": { "type": "object" }
