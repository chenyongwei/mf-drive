{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "toolpath-check-result.schema.json",
  "type": "object",
  "required": ["valid", "violations", "warnings"],
  "properties": {
    "valid": { "type": "boolean" },
    "violations": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["code", "message", "severity"],
        "properties": {
          "code": { "type": "string" },
          "message": { "type": "string" },
          "severity": { "type": "string", "enum": ["error", "warning"] },
          "contourId": { "type": "string" },
          "partId": { "type": "string" }
        },
        "additionalProperties": false
      }
    },
    "warnings": {
      "type": "array",
      "items": { "type": "string" }
    }
  },
  "additionalProperties": false
}
