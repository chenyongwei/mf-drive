{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["items", "total"],
  "properties": {
    "items": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["partId", "quantity"],
        "properties": {
          "partId": { "type": "string" },
          "quantity": { "type": "integer", "minimum": 1, "maximum": 9999 }
        }
      }
    },
    "total": { "type": "integer", "minimum": 0 }
  }
}
