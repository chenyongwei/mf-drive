{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": [
    "updatedAt",
    "tabs"
  ],
  "properties": {
    "updatedAt": {
      "type": "string"
    },
    "tabs": {
      "type": "object",
      "required": [
        "basic",
        "namingRules",
        "nestingParams",
        "displayEffects",
        "textRecognition",
        "myIndustry",
        "language"
      ],
      "properties": {
        "basic": {
          "type": "object",
          "required": [
            "autoSaveMinutes",
            "defaultCustomer",
            "timezone"
          ],
          "properties": {
            "autoSaveMinutes": {
              "type": "integer"
            },
            "defaultCustomer": {
              "type": "string"
            },
            "timezone": {
              "type": "string"
            }
          },
          "additionalProperties": true
        },
        "namingRules": {
          "type": "object",
          "required": [
            "jobPattern",
            "partPattern",
            "layoutPattern"
          ],
          "properties": {
            "jobPattern": {
              "type": "string"
            },
            "partPattern": {
              "type": "string"
            },
            "layoutPattern": {
              "type": "string"
            }
          },
          "additionalProperties": true
        },
        "nestingParams": {
          "type": "object",
          "required": [
            "spacingMm",
            "marginMm",
            "allowRotate"
          ],
          "properties": {
            "spacingMm": {
              "type": "number"
            },
            "marginMm": {
              "type": "integer"
            },
            "allowRotate": {
              "type": "boolean"
            }
          },
          "additionalProperties": true
        },
        "displayEffects": {
          "type": "object",
          "required": [
            "showGrid",
            "highContrast",
            "showPartLabels"
          ],
          "properties": {
            "showGrid": {
              "type": "boolean"
            },
            "highContrast": {
              "type": "boolean"
            },
            "showPartLabels": {
              "type": "boolean"
            }
          },
          "additionalProperties": true
        },
        "textRecognition": {
          "type": "object",
          "required": [
            "enabled",
            "lang",
            "confidenceThreshold"
          ],
          "properties": {
            "enabled": {
              "type": "boolean"
            },
            "lang": {
              "type": "string"
            },
            "confidenceThreshold": {
              "type": "number"
            }
          },
          "additionalProperties": true
        },
        "myIndustry": {
          "type": "object",
          "required": [
            "name",
            "preferredMaterial"
          ],
          "properties": {
            "name": {
              "type": "string"
            },
            "preferredMaterial": {
              "type": "string"
            }
          },
          "additionalProperties": true
        },
        "language": {
          "type": "object",
          "required": [
            "locale",
            "fallbackLocale"
          ],
          "properties": {
            "locale": {
              "type": "string"
            },
            "fallbackLocale": {
              "type": "string"
            }
          },
          "additionalProperties": true
        }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
