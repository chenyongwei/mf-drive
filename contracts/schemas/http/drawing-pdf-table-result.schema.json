{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "drawing-pdf-table-result.schema.json",
  "type": "object",
  "required": ["strategyUsed", "titleBlock", "attributes", "bomRows", "fieldConfidence"],
  "properties": {
    "strategyUsed": {
      "type": "array",
      "items": { "type": "string" }
    },
    "titleBlock": { "$ref": "drawing-pdf-title-block.schema.json" },
    "attributes": {
      "type": "array",
      "items": { "$ref": "drawing-pdf-table-attribute.schema.json" }
    },
    "bomRows": {
      "type": "array",
      "items": { "$ref": "drawing-pdf-bom-row.schema.json" }
    },
    "fieldConfidence": {
      "type": "object",
      "additionalProperties": { "type": "number" }
    }
  },
  "additionalProperties": false
}
