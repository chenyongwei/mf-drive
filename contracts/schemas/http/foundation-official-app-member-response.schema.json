{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "foundation-official-app-member-response.schema.json",
  "type": "object",
  "required": ["success", "membership"],
  "properties": {
    "success": { "type": "boolean" },
    "membership": {
      "type": "object",
      "required": ["membershipId", "tenantId", "appId", "subject", "role", "status", "createdAt", "updatedAt"],
      "properties": {
        "membershipId": { "type": "string" },
        "tenantId": { "type": "string" },
        "appId": {
          "type": "string",
          "enum": ["nesting", "drawing", "ordering", "crm", "aps", "wms", "drive", "foundation_workbench"]
        },
        "subject": { "type": "string" },
        "role": { "type": "string", "enum": ["OWNER", "MEMBER"] },
        "status": { "type": "string", "enum": ["ACTIVE", "REVOKED"] },
        "identityScopes": {
          "type": "array",
          "items": { "type": "string" }
        },
        "createdAt": { "type": "string" },
        "updatedAt": { "type": "string" },
        "revokedAt": { "type": "string" }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
