{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "foundation-bom-versions-response.schema.json",
  "type": "object",
  "required": ["items", "total"],
  "properties": {
    "items": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["versionId", "stage", "status", "createdAt", "partCount"],
        "properties": {
          "versionId": { "type": "string" },
          "stage": {
            "type": "string",
            "enum": ["EBOM", "PBOM", "MBOM"]
          },
          "status": {
            "type": "string",
            "enum": ["PENDING_ADOPTION", "ACTIVE", "ARCHIVED"]
          },
          "createdAt": { "type": "string" },
          "createdBy": { "type": "string" },
          "partCount": { "type": "integer", "minimum": 0 },
          "parentVersionId": { "type": "string" },
          "changeSummary": { "type": "string" }
        },
        "additionalProperties": false
      }
    },
    "total": { "type": "integer", "minimum": 0 }
  },
  "additionalProperties": false
}
