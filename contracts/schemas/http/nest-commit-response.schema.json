{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "nest-commit-response.schema.json",
  "type": "object",
  "required": ["nestingId", "status", "committedAt"],
  "properties": {
    "nestingId": { "type": "string" },
    "status": { "type": "string", "enum": ["committed"] },
    "committedAt": { "type": "string" },
    "records": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["partId", "sheetId", "quantity"],
        "properties": {
          "partId": { "type": "string" },
          "sheetId": { "type": "string" },
          "quantity": { "type": "integer", "minimum": 1 }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
