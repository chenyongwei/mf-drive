{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "drawing-pdf-cad-entity.schema.json",
  "type": "object",
  "required": ["id", "type", "geometry"],
  "properties": {
    "id": { "type": "string" },
    "type": { "type": "string", "enum": ["LINE", "POLYLINE", "ARC"] },
    "closed": { "type": "boolean" },
    "geometry": { "type": "object", "additionalProperties": true },
    "bbox": {
      "type": "object",
      "properties": {
        "minX": { "type": "number" },
        "minY": { "type": "number" },
        "maxX": { "type": "number" },
        "maxY": { "type": "number" }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": true
}
