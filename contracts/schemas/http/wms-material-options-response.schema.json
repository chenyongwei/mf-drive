{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["items", "total"],
  "properties": {
    "items": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "label", "type", "code"],
        "properties": {
          "id": { "type": "string" },
          "label": { "type": "string" },
          "type": { "type": "string", "enum": ["SHEET", "PIPE"] },
          "code": { "type": "string" }
        },
        "additionalProperties": true
      }
    },
    "total": {
      "type": "integer",
      "minimum": 0
    }
  },
  "additionalProperties": true
}
