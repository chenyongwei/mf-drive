{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "drawing-pdf-extract-response.schema.json",
  "type": "object",
  "required": ["jobId", "summary", "results", "errors"],
  "properties": {
    "jobId": { "type": "string" },
    "summary": {
      "type": "object",
      "required": ["totalFiles", "succeeded", "failed", "ocrUsedFiles", "durationMs"],
      "properties": {
        "totalFiles": { "type": "integer", "minimum": 0 },
        "succeeded": { "type": "integer", "minimum": 0 },
        "failed": { "type": "integer", "minimum": 0 },
        "ocrUsedFiles": { "type": "integer", "minimum": 0 },
        "durationMs": { "type": "integer", "minimum": 0 }
      },
      "additionalProperties": false
    },
    "results": {
      "type": "array",
      "items": { "$ref": "drawing-pdf-extract-result.schema.json" }
    },
    "errors": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["code", "message"],
        "properties": {
          "fileName": { "type": "string" },
          "code": { "type": "string" },
          "message": { "type": "string" },
          "detail": { "type": "string" }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
