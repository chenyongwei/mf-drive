{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["id", "name", "code", "hidden", "updatedAt", "specs"],
  "properties": {
    "id": { "type": "string" },
    "name": { "type": "string" },
    "code": { "type": "string" },
    "hidden": { "type": "boolean" },
    "updatedAt": { "type": "string" },
    "specs": {
      "type": "array",
      "items": { "$ref": "pipe-spec.schema.json" }
    }
  },
  "additionalProperties": false
}
