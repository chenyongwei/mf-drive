{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "foundation-security-pdp-evaluate-request.schema.json",
  "type": "object",
  "required": [
    "token",
    "tenantId",
    "consumerAppId",
    "resourcePackId",
    "selector",
    "action"
  ],
  "properties": {
    "token": {
      "type": "string"
    },
    "tenantId": {
      "type": "string"
    },
    "consumerAppId": {
      "type": "string",
      "enum": [
        "nesting",
        "drawing",
        "ordering",
        "crm",
        "aps",
        "wms",
        "drive",
        "foundation_workbench"
      ]
    },
    "resourcePackId": {
      "type": "string"
    },
    "selector": {
      "type": "object",
      "additionalProperties": true
    },
    "action": {
      "type": "string",
      "enum": [
        "read",
        "write",
        "share",
        "delete"
      ]
    },
    "at": {
      "type": "string"
    }
  },
  "additionalProperties": false
}
