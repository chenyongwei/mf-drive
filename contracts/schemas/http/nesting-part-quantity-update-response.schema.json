{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["partId", "quantity", "mode", "persisted"],
  "properties": {
    "partId": { "type": "string" },
    "quantity": { "type": "integer", "minimum": 1, "maximum": 9999 },
    "mode": { "type": "string", "enum": ["mock", "live"] },
    "persisted": { "type": "boolean" }
  }
}
