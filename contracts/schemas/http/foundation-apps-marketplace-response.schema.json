{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "foundation-apps-marketplace-response.schema.json",
  "type": "object",
  "required": ["accountAuthorized", "items", "total", "page", "pageSize", "categories"],
  "properties": {
    "accountAuthorized": { "type": "boolean" },
    "accountAuthorizedAt": { "type": "string" },
    "items": {
      "type": "array",
      "items": {
        "$ref": "foundation-app-marketplace-item.schema.json"
      }
    },
    "total": { "type": "integer", "minimum": 0 },
    "page": { "type": "integer", "minimum": 1 },
    "pageSize": { "type": "integer", "minimum": 1 },
    "categories": {
      "type": "array",
      "items": {
        "$ref": "foundation-app-marketplace-categories.schema.json"
      }
    }
  },
  "additionalProperties": false
}
