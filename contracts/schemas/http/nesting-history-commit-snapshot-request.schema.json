{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "nesting-history-commit-snapshot-request.schema.json",
  "type": "object",
  "required": ["snapshot"],
  "properties": {
    "snapshot": {
      "type": "object",
      "required": ["nestingParts", "plates", "partQuantities"],
      "properties": {
        "nestingParts": {
          "type": "array",
          "items": { "type": "object" }
        },
        "plates": {
          "type": "array",
          "items": { "type": "object" }
        },
        "partQuantities": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["partId", "quantity"],
            "properties": {
              "partId": { "type": "string" },
              "quantity": { "type": "integer", "minimum": 1, "maximum": 9999 }
            },
            "additionalProperties": true
          }
        }
      },
      "additionalProperties": true
    },
    "operationType": { "type": "string" },
    "operationData": { "type": "object" },
    "userId": { "type": "string" },
    "username": { "type": "string" }
  },
  "additionalProperties": false
}
