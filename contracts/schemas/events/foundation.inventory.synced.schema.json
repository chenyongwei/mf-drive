{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "foundation.inventory.synced.schema.json",
  "allOf": [
    { "$ref": "./event-envelope.schema.json" },
    {
      "type": "object",
      "properties": {
        "eventType": { "const": "foundation.inventory.synced" },
        "payload": {
          "type": "object",
          "required": ["syncId", "sheetCount", "source", "status"],
          "properties": {
            "syncId": { "type": "string" },
            "sheetCount": { "type": "integer", "minimum": 0 },
            "source": { "type": "string" },
            "status": { "type": "string", "enum": ["SUCCESS", "FAILED"] }
          },
          "additionalProperties": false
        }
      }
    }
  ]
}
