{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "foundation.sheet.consumption.rolledback.schema.json",
  "allOf": [
    { "$ref": "./event-envelope.schema.json" },
    {
      "type": "object",
      "properties": {
        "eventType": { "const": "foundation.sheet.consumption.rolledback" },
        "payload": {
          "type": "object",
          "required": ["recordId", "reservationId", "reason"],
          "properties": {
            "recordId": { "type": "string" },
            "reservationId": { "type": "string" },
            "reason": { "type": "string" }
          },
          "additionalProperties": false
        }
      }
    }
  ]
}
