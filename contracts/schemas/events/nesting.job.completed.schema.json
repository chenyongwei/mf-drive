{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "nesting.job.completed.schema.json",
  "allOf": [
    { "$ref": "./event-envelope.schema.json" },
    {
      "type": "object",
      "properties": {
        "eventType": { "const": "nesting.job.completed" },
        "payload": {
          "type": "object",
          "required": ["jobId", "utilization"],
          "properties": {
            "jobId": { "type": "string" },
            "utilization": { "type": "number", "minimum": 0, "maximum": 1 }
          },
          "additionalProperties": false
        }
      }
    }
  ]
}
