{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "foundation.sheet.consumption.committed.schema.json",
  "allOf": [
    { "$ref": "./event-envelope.schema.json" },
    {
      "type": "object",
      "properties": {
        "eventType": { "const": "foundation.sheet.consumption.committed" },
        "payload": {
          "type": "object",
          "required": ["recordId", "reservationId", "sheetId", "consumedQuantity"],
          "properties": {
            "recordId": { "type": "string" },
            "reservationId": { "type": "string" },
            "sheetId": { "type": "string" },
            "consumedQuantity": { "type": "integer", "minimum": 1 }
          },
          "additionalProperties": false
        }
      }
    }
  ]
}
