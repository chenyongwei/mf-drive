{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "foundation.sheet.reservation.created.schema.json",
  "allOf": [
    { "$ref": "./event-envelope.schema.json" },
    {
      "type": "object",
      "properties": {
        "eventType": { "const": "foundation.sheet.reservation.created" },
        "payload": {
          "type": "object",
          "required": ["reservationId", "sheetId", "quantity", "status"],
          "properties": {
            "reservationId": { "type": "string" },
            "sheetId": { "type": "string" },
            "quantity": { "type": "integer", "minimum": 1 },
            "status": { "const": "RESERVED" }
          },
          "additionalProperties": false
        }
      }
    }
  ]
}
