{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "foundation.bom.version.adopted.schema.json",
  "allOf": [
    { "$ref": "./event-envelope.schema.json" },
    {
      "type": "object",
      "properties": {
        "eventType": { "const": "foundation.bom.version.adopted" },
        "payload": {
          "type": "object",
          "required": ["versionId", "status", "adoptedBy"],
          "properties": {
            "versionId": { "type": "string" },
            "status": { "const": "ACTIVE" },
            "adoptedBy": { "type": "string" }
          },
          "additionalProperties": false
        }
      }
    }
  ]
}
