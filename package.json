{
  "name": "drive",
  "version": "0.1.0",
  "private": true,
  "description": "Drive repo (drive-api) for drawings/parts/layout artifacts",
  "scripts": {
    "dev:mock:api": "npm --prefix ./api run dev:mock:watch",
    "dev:mock:web": "npm --prefix ./web run dev:mock",
    "dev:live:api": "npm --prefix ./api run dev:live",
    "dev:live:web": "npm --prefix ./web run dev:live",
    "dev:mock": "bash -lc 'npm run dev:mock:api & npm run dev:mock:web & wait'",
    "dev:live": "bash -lc 'npm run dev:live:api & npm run dev:live:web & wait'",
    "build:web": "npm --prefix ./web run build",
    "test:mock": "npm --prefix ./api run test:mock && npm --prefix ./web run test:mock",
    "contract:test": "tsx scripts/contract-test.ts",
    "contract:check": "tsx scripts/contract-check.ts"
  },
  "devDependencies": {
    "tsx": "^4.20.3"
  }
}
