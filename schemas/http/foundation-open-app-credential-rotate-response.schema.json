{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "foundation-open-app-credential-rotate-response.schema.json",
  "type": "object",
  "required": ["success", "openAppId", "credential"],
  "properties": {
    "success": { "type": "boolean" },
    "openAppId": { "type": "string" },
    "credential": {
      "type": "object",
      "required": ["credentialId", "appKey", "appSecret", "createdAt"],
      "properties": {
        "credentialId": { "type": "string" },
        "appKey": { "type": "string" },
        "appSecret": { "type": "string" },
        "createdAt": { "type": "string" }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
