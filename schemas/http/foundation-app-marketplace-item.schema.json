{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "foundation-app-marketplace-item.schema.json",
  "type": "object",
  "required": [
    "appId",
    "name",
    "route",
    "clientId",
    "enabledByUser",
    "requiredBaseScope",
    "launchMode",
    "miniSupported",
    "l1Authorized",
    "resourceGrantCount",
    "category",
    "tagline",
    "shortDescription",
    "tags",
    "highlights",
    "updatedAt",
    "ratingAverage",
    "ratingCount",
    "installCount",
    "featured"
  ],
  "properties": {
    "appId": { "type": "string" },
    "name": { "type": "string" },
    "route": { "type": "string" },
    "clientId": { "type": "string" },
    "enabledByUser": { "type": "boolean" },
    "requiredBaseScope": { "type": "string" },
    "launchMode": { "type": "string", "enum": ["MINI", "NEW_WINDOW"] },
    "miniSupported": { "type": "boolean" },
    "installedAt": { "type": "string" },
    "l1Authorized": { "type": "boolean" },
    "membershipRole": { "type": "string", "enum": ["OWNER", "MEMBER"] },
    "resourceGrantCount": { "type": "integer", "minimum": 0 },
    "authorizationWindow": {
      "type": "object",
      "required": ["startsAt", "endsAt"],
      "properties": {
        "startsAt": { "type": "string" },
        "endsAt": { "type": "string" }
      },
      "additionalProperties": false
    },
    "category": { "type": "string" },
    "tagline": { "type": "string" },
    "shortDescription": { "type": "string" },
    "tags": {
      "type": "array",
      "items": { "type": "string" }
    },
    "highlights": {
      "type": "array",
      "items": { "type": "string" }
    },
    "updatedAt": { "type": "string" },
    "ratingAverage": { "type": "number", "minimum": 0, "maximum": 5 },
    "ratingCount": { "type": "integer", "minimum": 0 },
    "installCount": { "type": "integer", "minimum": 0 },
    "featured": { "type": "boolean" },
    "longDescription": { "type": "string" },
    "screenshots": {
      "type": "array",
      "items": { "type": "string" }
    },
    "version": { "type": "string" },
    "permissionScopes": {
      "type": "array",
      "items": { "type": "string" }
    },
    "permissionsSummary": { "type": "string" }
  },
  "additionalProperties": false
}
