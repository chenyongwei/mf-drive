{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["items", "total"],
  "properties": {
    "items": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["containerId", "tenantId", "ownerAppId", "mode", "name", "quotaBytes", "usedBytes", "createdAt"],
        "properties": {
          "containerId": { "type": "string" },
          "tenantId": { "type": "string" },
          "ownerAppId": { "type": "string" },
          "mode": { "type": "string", "enum": ["APP_DATA", "MY_DRIVE"] },
          "name": { "type": "string" },
          "quotaBytes": { "type": "integer", "minimum": 0 },
          "usedBytes": { "type": "integer", "minimum": 0 },
          "createdAt": { "type": "string" }
        },
        "additionalProperties": true
      }
    },
    "total": {
      "type": "integer",
      "minimum": 0
    }
  },
  "additionalProperties": true
}
