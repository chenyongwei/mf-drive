{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "foundation-security-ontology-vocab-response.schema.json",
  "type": "object",
  "required": ["dataDomains", "purposes", "retentions", "revocationModes", "defaults"],
  "properties": {
    "dataDomains": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": ["ORDER", "DRAWING", "NESTING", "INVENTORY", "FILE", "FOUNDATION_MODEL", "CUSTOMER", "SCHEDULING"]
      }
    },
    "purposes": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "OPS_DISPATCH",
          "PRODUCTION_PLANNING",
          "QUALITY_TRACEABILITY",
          "SUPPLY_CHAIN_COLLAB",
          "FILE_ARCHIVAL",
          "ANALYTICS_REPORTING",
          "CUSTOMER_DELIVERY",
          "ALGORITHM_TRAINING"
        ]
      }
    },
    "retentions": {
      "type": "array",
      "items": { "type": "string", "enum": ["P7D", "P30D", "P90D", "P180D"] }
    },
    "revocationModes": {
      "type": "array",
      "items": { "type": "string", "enum": ["IMMEDIATE_CASCADE", "SOFT_GRACE_24H"] }
    },
    "defaults": {
      "type": "object",
      "required": ["retention", "revocationMode"],
      "properties": {
        "retention": { "type": "string", "enum": ["P7D", "P30D", "P90D", "P180D"] },
        "revocationMode": { "type": "string", "enum": ["IMMEDIATE_CASCADE", "SOFT_GRACE_24H"] }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
