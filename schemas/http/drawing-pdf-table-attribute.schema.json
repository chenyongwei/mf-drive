  "$id": "drawing-pdf-table-attribute.schema.json",
  "type": "object",
  "required": ["key", "value"],
  "properties": {
    "key": { "type": "string" },
    "value": { "type": "string" },
    "confidence": { "type": "number" },
    "source": {
      "type": "string",
      "enum": ["text", "ocr", "mixed"]
    }
  },
  "additionalProperties": false
}
