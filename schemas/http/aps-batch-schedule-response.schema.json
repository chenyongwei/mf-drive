{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "aps-batch-schedule-response.schema.json",
  "type": "object",
  "required": ["success", "affected", "machine", "records"],
  "properties": {
    "success": { "type": "boolean" },
    "affected": { "type": "integer", "minimum": 0 },
    "machine": { "$ref": "aps-machine-row.schema.json" },
    "records": {
      "type": "array",
      "items": { "$ref": "aps-schedule-record-row.schema.json" }
    }
  },
  "additionalProperties": false
}
