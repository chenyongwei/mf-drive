{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "drawing-pdf-extract-request.schema.json",
  "type": "object",
  "required": ["files"],
  "properties": {
    "files": {
      "type": "array",
      "minItems": 1,
      "maxItems": 50,
      "items": {
        "type": "object",
        "required": ["fileName", "mimeType", "base64"],
        "properties": {
          "fileName": { "type": "string" },
          "mimeType": {
            "type": "string",
            "enum": [
              "application/pdf",
              "image/png",
              "image/jpeg",
              "image/jpg",
              "image/webp",
              "image/bmp",
              "image/tiff",
              "image/x-tiff"
            ]
          },
          "base64": { "type": "string" }
        },
        "additionalProperties": false
      }
    },
    "options": {
      "type": "object",
      "properties": {
        "table": {
          "type": "object",
          "properties": {
            "mode": { "type": "string", "enum": ["balanced", "recall", "precision"] },
            "extractTitleBlock": { "type": "boolean" },
            "extractBom": { "type": "boolean" }
          },
          "additionalProperties": false
        },
        "cad": {
          "type": "object",
          "properties": {
            "enable": { "type": "boolean" },
            "extractContours": { "type": "boolean" },
            "partRecognitionMode": { "type": "string", "enum": ["off", "analyze", "recognize"] }
          },
          "additionalProperties": false
        },
        "ocr": {
          "type": "object",
          "properties": {
            "enableFallback": { "type": "boolean" },
            "language": { "type": "string" },
            "minTextChars": { "type": "integer", "minimum": 0 }
          },
          "additionalProperties": false
        },
        "entityLimit": { "type": "integer", "minimum": 100 }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
