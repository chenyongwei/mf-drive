{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "toolpath-override.schema.json",
  "type": "object",
  "properties": {
    "startPointOverrides": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["contourId", "startPointParam"],
        "properties": {
          "contourId": { "type": "string" },
          "startPointParam": { "type": "number", "minimum": 0, "maximum": 1 },
          "direction": { "type": "string", "enum": ["CW", "CCW"] }
        },
        "additionalProperties": false
      }
    },
    "leadOverrides": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["contourId"],
        "properties": {
          "contourId": { "type": "string" },
          "leadIn": {
            "type": "object",
            "required": ["enabled", "length", "angleDeg"],
            "properties": {
              "enabled": { "type": "boolean" },
              "length": { "type": "number", "minimum": 0 },
              "angleDeg": { "type": "number" }
            },
            "additionalProperties": false
          },
          "leadOut": {
            "type": "object",
            "required": ["enabled", "length", "angleDeg"],
            "properties": {
              "enabled": { "type": "boolean" },
              "length": { "type": "number", "minimum": 0 },
              "angleDeg": { "type": "number" }
            },
            "additionalProperties": false
          }
        },
        "additionalProperties": false
      }
    },
    "sequenceOverrides": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["contourId", "order"],
        "properties": {
          "contourId": { "type": "string" },
          "order": { "type": "integer", "minimum": 0 }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
