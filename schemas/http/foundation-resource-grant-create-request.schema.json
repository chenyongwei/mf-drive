{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "foundation-resource-grant-create-request.schema.json",
  "type": "object",
  "required": [
    "tenantId",
    "sourceAppId",
    "consumerAppId",
    "resourcePackId",
    "selector",
    "actions",
    "startsAt",
    "endsAt"
  ],
  "properties": {
    "tenantId": { "type": "string" },
    "sourceAppId": {
      "type": "string",
      "enum": ["nesting", "drawing", "ordering", "crm", "aps", "wms", "drive", "foundation_workbench"]
    },
    "consumerAppId": {
      "type": "string",
      "enum": ["nesting", "drawing", "ordering", "crm", "aps", "wms", "drive", "foundation_workbench"]
    },
    "resourcePackId": { "type": "string" },
    "selector": { "type": "object", "additionalProperties": true },
    "actions": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "enum": ["read", "write", "share", "delete"] }
    },
    "startsAt": { "type": "string" },
    "endsAt": { "type": "string" }
  },
  "additionalProperties": false
}
