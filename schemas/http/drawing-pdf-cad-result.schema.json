{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "drawing-pdf-cad-result.schema.json",
  "type": "object",
  "required": ["entities", "contours", "stats", "truncated", "page"],
  "properties": {
    "approximate": { "type": "boolean" },
    "entities": {
      "type": "array",
      "items": { "$ref": "drawing-pdf-cad-entity.schema.json" }
    },
    "contours": {
      "type": "array",
      "items": { "$ref": "drawing-pdf-cad-contour.schema.json" }
    },
    "stats": {
      "type": "object",
      "required": ["entityCount", "lineCount", "polylineCount", "arcCount", "closedContourCount", "openContourCount"],
      "properties": {
        "entityCount": { "type": "integer", "minimum": 0 },
        "lineCount": { "type": "integer", "minimum": 0 },
        "polylineCount": { "type": "integer", "minimum": 0 },
        "arcCount": { "type": "integer", "minimum": 0 },
        "closedContourCount": { "type": "integer", "minimum": 0 },
        "openContourCount": { "type": "integer", "minimum": 0 }
      },
      "additionalProperties": false
    },
    "truncated": { "type": "boolean" },
    "page": {
      "type": "object",
      "required": ["width", "height"],
      "properties": {
        "width": { "type": "number" },
        "height": { "type": "number" }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
